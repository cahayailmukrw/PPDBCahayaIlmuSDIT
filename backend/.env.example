# Database Connection String
# For local development with PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/ppdb

# For Vercel deployment with Supabase/Neon:
# DATABASE_URL=postgresql://username:password@host:port/database

# Example with Supabase:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# Example with Neon:
# DATABASE_URL=postgresql://[YOUR-USER]:[YOUR-PASSWORD]@[YOUR-HOST].neon.tech/neondb

# Server Port (optional, Vercel will set this automatically)
# PORT=3000

# Node Environment
# NODE_ENV=development
