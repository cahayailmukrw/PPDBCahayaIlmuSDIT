generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  name           String
  role           Role      @default(USER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  registrations  Registration[]
  notifications  Notification[]
}

enum Role {
  ADMIN
  USER
}

model Parent {
  id            String    @id @default(uuid())
  fatherName    String
  motherName    String
  fatherJob     String
  motherJob     String
  income        String
  phone         String
  email         String
  address       String
  student       Student?
}

model Student {
  id              String       @id @default(uuid())
  fullName        String
  nik             String
  nisn            String
  birthPlace      String
  birthDate       DateTime
  gender          String
  religion        String
  address         String
  originSchool    String
  siblingOrder    Int
  siblingCount    Int
  programChoice   ProgramType
  status          RegistrationStatus @default(PENDING)
  parent          Parent       @relation(fields: [parentId], references: [id])
  parentId        String
  registration    Registration?
  documents       Document[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum ProgramType {
  TAHFIDZ
  REGULER
}

enum RegistrationStatus {
  PENDING
  VERIFIED
  ACCEPTED
  REJECTED
  WAITLIST
}

model Registration {
  id               String    @id @default(uuid())
  registrationNo   String    @unique
  student          Student   @relation(fields: [studentId], references: [id])
  studentId        String
  user             User?     @relation(fields: [userId], references: [id])
  userId           String?
  verificationNote String?
  verified         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Document {
  id          String    @id @default(uuid())
  fileName    String
  filePath    String
  fileType    String
  student     Student   @relation(fields: [studentId], references: [id])
  studentId   String
  createdAt   DateTime  @default(now())
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String
  status      AnnouncementStatus @default(PUBLISHED)
  publishedAt DateTime @default(now())
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}

model Notification {
  id          String   @id @default(uuid())
  title       String
  message     String
  recipient   String
  sentAt      DateTime @default(now())
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
}
